{
  "name": "quiz0r",
  "version": "0.1.0",
  "description": "Quiz0r desktop app",
  "author": "Jonathan Isaacs",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "prebuild": "cd .. && npm run build"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "24.12.0"
  },
  "build": {
    "appId": "dev.err0r.quiz0r",
    "productName": "Quiz0r",
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": "../.next/standalone",
        "to": "next/standalone"
      },
      {
        "from": "../.next/static",
        "to": "next/static"
      },
      {
        "from": "../public",
        "to": "next/public"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true
    },
    "win": {
      "target": "nsis"
    }
  }
}
