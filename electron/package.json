{
  "name": "quiz0r",
  "version": "0.1.0",
  "description": "Quiz0r desktop app",
  "author": "Jonathan Isaacs",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "node ./scripts/run-build.js"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "24.12.0"
  },
  "build": {
    "appId": "dev.err0r.quiz0r",
    "productName": "Quiz0r",
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": "../.next/standalone",
        "to": "next/standalone"
      },
      {
        "from": "../.next/static",
        "to": "next/static"
      },
      {
        "from": "../public",
        "to": "next/public"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.inherit.plist",
      "identity": "Developer ID Application",
      "notarize": {
        "teamId": "${env:APPLE_TEAM_ID}",
        "appleId": "${env:APPLEID}",
        "appleIdPassword": "${env:APPLEIDPASS}"
      }
    },
    "win": {
      "target": "nsis",
      "certificateFile": "${env:CSC_LINK}",
      "certificatePassword": "${env:CSC_KEY_PASSWORD}",
      "certificateSubjectName": "Quiz0r"
    }
  }
}
